# Supabase (required in all environments)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# PI service base URL (iframe / redirect target)
# dev:  http://localhost:3131
# stg:  https://stg.jpglabs.com.br/pi
# prod: https://jpglabs.com.br/pi
VITE_PI_SERVICE_URL=

# Portfolio API base URL
# dev:  http://localhost:3000
# stg:  https://stg.jpglabs.com.br
# prod: https://jpglabs.com.br
VITE_API_URL=

# Optional: override the Vite base path (default: /)
# VITE_BASE_PATH=/
